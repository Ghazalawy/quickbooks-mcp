APP_ENV=production
LOG_LEVEL=INFO
LOG_FILE=/opt/quickbooks-mcp/logs/app.log

# Public HTTPS base URL used by Intuit redirect URI and by your MCP client registration.
PUBLIC_BASE_URL=https://qb-mcp.yourdomain.com
HOST=0.0.0.0
PORT=8765
ALLOWED_HOSTS=qb-mcp.yourdomain.com,localhost,127.0.0.1
CORS_ALLOW_ORIGINS=

# Protect the MCP endpoint with a bearer token.
MCP_BEARER_TOKEN=replace_with_long_random_secret

# Protect admin pages (/status and /auth/connect) with HTTP Basic Auth.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_random_password
STATUS_PAGE_ENABLED=true

# Intuit / QuickBooks
QB_CLIENT_ID=replace_with_intuit_client_id
QB_CLIENT_SECRET=replace_with_intuit_client_secret
QB_REDIRECT_URI=
QB_ENVIRONMENT=production
QB_SCOPES=com.intuit.quickbooks.accounting
QB_DEFAULT_REALM_ID=
QB_REQUEST_TIMEOUT_SECONDS=45
QB_RETRY_ATTEMPTS=3

# Database
# Single-node deployment: SQLite example
DATABASE_URL=sqlite:///./data/quickbooks_mcp.sqlite3
# Multi-instance deployment: PostgreSQL example
# DATABASE_URL=postgresql+psycopg://qb_mcp_user:strongpassword@127.0.0.1:5432/qb_mcp

# REQUIRED in production. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
QB_TOKEN_ENCRYPTION_KEY=

# Writes are OFF by default. Keep them off until you validate item/customer IDs end-to-end.
QB_ENABLE_INVOICE_WRITE=false
QB_MAX_INVOICE_TOTAL=50000.00
QB_REQUIRE_IDEMPOTENCY_KEY=true
